NODE_ENV=development
API_PORT=3120

# SMTP (leave SMTP_HOST unset in dev to log submissions to the console instead of sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

CONTACT_TO=info@authorglennmosby.com
CONTACT_FROM_EMAIL="Old Farmer John Had a Farm" <no-reply@authorglennmosby.com>

# Stripe (leave both unset to run the site with checkout disabled — the
# checkout form will show a friendly "not available yet" message and log
# the attempted order to the console instead)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
